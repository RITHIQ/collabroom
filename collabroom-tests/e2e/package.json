{
  "name": "collabroom-selenium-e2e",
  "version": "1.0.0",
  "scripts": {
    "test": "mocha --recursive tests/ --timeout 60000 --reporter mochawesome --reporter-options reportDir=reports,reportFilename=E2E_Report",
    "test:chrome": "cross-env BROWSER=chrome npm test",
    "test:firefox": "cross-env BROWSER=firefox npm test",
    "test:edge": "cross-env BROWSER=edge npm test",
    "test:headless": "cross-env HEADLESS=true npm test",
    "test:parallel": "mocha --parallel --recursive tests/ --timeout 60000",
    "report": "node utilities/ExcelReporter.js"
  },
  "dependencies": {
    "selenium-webdriver": "^4.18.1",
    "mocha": "^10.4.0",
    "chai": "^4.4.1",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0",
    "exceljs": "^4.4.0",
    "winston": "^3.13.0",
    "chromedriver": "^124.0.0",
    "geckodriver": "^4.3.3",
    "dotenv": "^16.0.0",
    "cross-env": "^7.0.3"
  }
}
