VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: GPT-4-class support chat (Help widget).
# Dev / vite preview: Vite proxies /__openai → api.openai.com and injects this key (avoids browser CORS).
VITE_OPENAI_API_KEY=
# Or use OPENAI_API_KEY (read only by vite.config.ts for the proxy, not bundled).
OPENAI_API_KEY=

# e.g. gpt-4o, gpt-4-turbo
VITE_OPENAI_MODEL=gpt-4o

# Production static sites: URL of your backend that forwards chat completions (OpenAI blocks direct browser calls).
# VITE_OPENAI_PROXY_URL=https://your-api.example.com

